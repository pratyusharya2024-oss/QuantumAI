from Core.logic_engine import Logic_Engine
 
def register(engine: Logic_Engine) -> None:
    Q, m, c, T, T1, T2, W, P, V, n, R, gamma = symbols('Q m c T T1 T2 W P V n R gamma')
    engine.register_formula('heat_energy',           Eq(Q, m * c * (T2 - T1)))
