def hydrogen_spectrum_summary(n_initial, Z=1):
    """Prints all emission lines from a given level down to n=1."""
    print("=" * 52)
    print(f"   HYDROGEN EMISSION SPECTRUM (n={n_initial} → lower)")
    print("=" * 52)
    for n_final in range(1, n_initial):
        delta_E = abs(photon_energy_transition(n_initial, n_final, Z))
        lam     = photon_wavelength_transition(n_initial, n_final, Z)
        series  = spectral_series_name(n_final)
        print(f"  n={n_initial} → n={n_final}  |  ΔE={delta_E:.4f} eV  |  λ={lam*1e9:.4f} nm  |  {series}")
    print("=" * 52)


def radioactive_summary(N_initial, half_life, time):
    """Prints decay status at a given time."""
    lam    = decay_constant(half_life)
    N_left = remaining_nuclei(N_initial, half_life, time)
    A_now  = activity(N_left, lam)
    frac   = N_left / N_initial * 100
    print("=" * 45)
    print("      RADIOACTIVE DECAY SUMMARY")
    print("=" * 45)
    print(f"  Initial Nuclei  : {N_initial:.3e}")
    print(f"  Half-life       : {half_life} s")
    print(f"  Time elapsed    : {time} s")
    print("-" * 45)
    print(f"  Remaining       : {N_left:.3e}  ({frac:.2f}%)")
    print(f"  Activity        : {A_now:.3e} Bq")
    print("=" * 45)


def photoelectric_summary(frequency, work_function_eV):
    """Prints photoelectric effect summary."""
    print("=" * 45)
    print("    PHOTOELECTRIC EFFECT SUMMARY")
    print("=" * 45)
    print(f"  Frequency       : {frequency:.3e} Hz")
    print(f"  Work Function   : {work_function_eV} eV")
    print("-" * 45)
    possible = is_photoelectric_emission_possible(frequency, work_function_eV)
    print(f"  Emission?       : {'YES' if possible else 'NO'}")
    if possible:
        ke = photoelectric_max_ke(frequency, work_function_eV)
