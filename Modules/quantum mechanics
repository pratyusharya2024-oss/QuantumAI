# SIMULATION — Radioactive Decay (NumPy)
# ─────────────────────────────────────────────

def simulate_radioactive_decay(N_initial, half_life, total_time, steps=1000):
    """
    Simulates radioactive decay over time.
    Returns DataFrame with time, nuclei remaining, activity.
    """
    lam = decay_constant(half_life)
    t   = np.linspace(0, total_time, steps)
    N   = N_initial * np.exp(-lam * t)
    A   = lam * N

    df = pd.DataFrame({
        "time"              : t,
        "nuclei remaining"  : N,
        "activity (Bq)"     : A
    })
    return df


def simulate_energy_levels_hydrogen(n_max=10, Z=1):
    """
    Simulates and returns energy levels and orbital radii for hydrogen-like atom.
    Returns DataFrame with n, energy (eV), radius (m), wavelength to n=1 (m).
    """
    levels = []
    for n in range(1, n_max + 1):
        E  = bohr_energy_level(n, Z)
        r  = bohr_radius_level(n, Z)
        if n > 1:
            lam = photon_wavelength_transition(n, 1, Z)
        else:
            lam = None
        levels.append({
            "n"                         : n,
            "energy (eV)"               : E,
            "orbital radius (m)"        : r,
            "emission wavelength (m)"   : lam
        })
    df = pd.DataFrame(levels)
    return df


def save_simulation_to_csv(df, filename="quantum_simulation.csv"):
    """Saves simulation DataFrame to CSV in data/ folder."""
    path = f"data/{filename}"
    df.to_csv(path, index=False)
    print(f"Simulation saved to {path}")


